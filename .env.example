# RoyalBot Portal Docker 环境配置示例
# 复制此文件为 .env 并修改相应配置

# ==================== 数据库配置 ====================
# PostgreSQL 密码（请修改为强密码）
POSTGRES_PASSWORD=your_secure_postgres_password_here

# Redis 密码（请修改为强密码）
REDIS_PASSWORD=your_secure_redis_password_here

# ==================== JWT 配置 ====================
# 管理后台 JWT 密钥 (admin_backend)
# 生成命令: python -c 'import secrets; print(secrets.token_urlsafe(32))'
JWT_SECRET_KEY=your_jwt_secret_key_minimum_32_characters_here

# 用户端 JWT 密钥 (user_backend) - 与管理后台使用不同密钥
SECRET_KEY=your_secret_key_minimum_32_characters_here

# ==================== 应用配置 ====================
# API 地址（用于前端和回调）
API_URL=https://your-domain.com
EXTERNAL_API_URL=https://your-domain.com

# 前端 URL（用于 CORS）
FRONTEND_URL=https://your-domain.com
ADDITIONAL_CORS_ORIGINS=https://your-domain.com,http://your-ip

# Vite 构建时使用的 API 地址
VITE_API_BASE_URL=https://your-domain.com

# 调试模式（生产环境必须为 False）
DEBUG=False

# ==================== 管理员配置 ====================
# 管理后台默认管理员密码（请修改为强密码，至少12位）
DEFAULT_ADMIN_PASSWORD=YourAdminPassword123!@#

# ==================== Telegram 配置 ====================
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=your_bot_username
TELEGRAM_ADMIN_ID=123456789

# ==================== 支付配置 ====================
# 易支付网关地址
YIPAY_GATEWAY_URL=https://pay.example.com/submit.php
YIPAY_PARTNER_ID=your_partner_id
YIPAY_KEY=your_merchant_key
# 订阅支付回调地址
YIPAY_NOTIFY_URL=https://your-domain.com/api/user/payment/notify
YIPAY_RETURN_URL=https://your-domain.com/payment/return
# 充值支付回调地址
YIPAY_RECHARGE_NOTIFY_URL=https://your-domain.com/api/user/recharge/notify
YIPAY_RECHARGE_RETURN_URL=https://your-domain.com/recharge/return

# ==================== 监控配置 ====================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here

# ==================== 安全配置 ====================
# 最小密码长度（建议至少12位）
MIN_PASSWORD_LENGTH=12

# 登录失败锁定
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=30

# 定时任务 API 鉴权密钥（用于手动触发定时任务）
# 生成命令: python -c 'import secrets; print(secrets.token_urlsafe(32))'
CRON_SECRET=your_cron_secret_key_minimum_32_characters_here

# 加密密钥（用于加密 Emby API Key 等敏感数据）
# 生成命令: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
CRYPTO_KEY=your_fernet_encryption_key_here

# ==================== 外部数据库配置 ====================
# 主项目数据库路径（用于获取 Telegram 用户积分等信息）
# 如果主项目数据库不存在，余额支付功能将不可用
ROYALBOT_DB_PATH=/root/royalbot/royalbot.db
