# ==============================================================================
# RoyalBot Portal - 环境配置模板
# ==============================================================================
# 说明: 复制此文件为 .env 并填写实际配置值
# 使用: cp .env.template .env
# ==============================================================================

# ==================== 数据库配置 ====================
# PostgreSQL 数据库密码 (建议使用强密码生成器)
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD

# Redis 密码
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ==================== JWT 配置 ====================
# 管理后台 JWT 密钥 (admin_backend)
# 必须至少 64 字符，建议使用: openssl rand -base64 64
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET_KEY_MIN_64_CHARS

# 用户端 JWT 密钥 (user_backend) - 与管理后台使用不同密钥
SECRET_KEY=CHANGE_ME_USER_SECRET_KEY_MIN_64_CHARS

# ==================== 应用配置 ====================
# API 地址（用于前端和回调）
API_URL=https://your-domain.com
EXTERNAL_API_URL=https://your-domain.com

# 前端 URL（用于 CORS）
FRONTEND_URL=https://your-domain.com
ADDITIONAL_CORS_ORIGINS=https://your-domain.com,http://your-server-ip

# Vite 构建时使用的 API 地址
VITE_API_BASE_URL=https://your-domain.com

# 调试模式（生产环境必须为 False）
DEBUG=False

# ==================== 管理员配置 ====================
# 管理后台默认管理员密码
# 警告：首次部署后请立即修改管理员密码！
DEFAULT_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# ==================== Telegram 配置 ====================
# 主 Bot 配置
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN
TELEGRAM_BOT_USERNAME=YOUR_BOT_USERNAME
TELEGRAM_ADMIN_ID=YOUR_ADMIN_TELEGRAM_ID

# ==================== 支付配置 (可选) ====================
YIPAY_GATEWAY_URL=YOUR_PAYMENT_GATEWAY_URL
YIPAY_PARTNER_ID=YOUR_PARTNER_ID
YIPAY_KEY=YOUR_PAYMENT_KEY
YIPAY_NOTIFY_URL=https://your-domain.com/api/user/payment/notify
YIPAY_RETURN_URL=https://your-domain.com/payment/return
YIPAY_RECHARGE_NOTIFY_URL=https://your-domain.com/api/user/recharge/notify
YIPAY_RECHARGE_RETURN_URL=https://your-domain.com/recharge/return

# ==================== 监控配置 ====================
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_GRAFANA_PASSWORD

# ==================== 安全配置 ====================
# 最小密码长度
MIN_PASSWORD_LENGTH=12
# 登录失败锁定次数
MAX_LOGIN_ATTEMPTS=5
# 锁定时长（分钟）
LOCKOUT_DURATION_MINUTES=30

# ==================== Cookie 配置 ====================
# Cookie 域名 (注意前面的点，支持所有子域名)
COOKIE_DOMAIN=.your-domain.com
# 是否启用 Cookie 认证 (true/false)
ENABLE_COOKIE_AUTH=true

# ==================== 日志配置 ====================
# 日志级别: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# ==================== 外部数据库配置 ====================
# 主项目数据库路径（用于获取 Telegram 用户积分等信息）
ROYALBOT_DB_PATH=/root/royalbot/royalbot.db

# ==================== Telegram 登录 Bot ====================
TELEGRAM_LOGIN_BOT_TOKEN=YOUR_LOGIN_BOT_TOKEN
WEB_URL=https://your-domain.com
ADMIN_IDS=YOUR_ADMIN_TELEGRAM_ID

# ==================== 加密密钥 ====================
# 用于加密 API Key 等敏感数据（至少 32 字符）
CRYPTO_KEY=CHANGE_ME_CRYPTO_KEY_MIN_32_CHARS
